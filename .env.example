# Backend / Django
# The app connects as a NON-superuser role so Postgres row-level security actually enforces
# (ADR-0002). The superuser `tenantiq` is bootstrap-only; `tenantiq_app` is created by
# infra/postgres/init/10-app-role.sql on first DB init.
DATABASE_URL=postgresql://tenantiq_app:tenantiq_app@localhost:5432/tenantiq
REDIS_URL=redis://localhost:6379/0
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver
ANTHROPIC_API_KEY=

# OIDC: per-tenant issuers are stored in the DB (Tenant.oidc_issuer) and are authoritative.
# This is only a dev bootstrap default pointing at the local Keycloak realm.
OIDC_ISSUER_URL=http://localhost:8080/realms/acme

# Keycloak (docker-compose `dev` profile) — local admin console credentials only
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
