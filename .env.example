# Copy to `.env` (`make dev` does this for you). Two consumers (#23):
#   - Host runs (python manage.py ...): the backend loads this file via python-dotenv, so these
#     localhost URLs are what take effect — start the datastores with `docker compose up db redis`.
#   - `docker compose up` (full stack): the app runs *inside* the compose network, so each service
#     overrides the infra hostnames to db/redis/ollama; the secrets/tunables below still apply.
#
# Backend / Django
# The app connects as a NON-superuser role so Postgres row-level security actually enforces
# (ADR-0002). The superuser `tenantiq` is bootstrap-only; `tenantiq_app` is created by
# infra/postgres/init/10-app-role.sql on first DB init.
DATABASE_URL=postgresql://tenantiq_app:tenantiq_app@localhost:5432/tenantiq
REDIS_URL=redis://localhost:6379/0
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver
ANTHROPIC_API_KEY=

# Per-tenant rate limiting & quotas (#49, ADR-0011). Limits are configuration, not code. Rates are
# per tenant per scope; quotas cap total query volume per tenant per calendar window (0 = unlimited).
# Throttle counters live in the cache — CACHE_URL defaults to REDIS_URL so they are shared across
# workers (a per-process cache would enforce N x the rate under N workers).
# CACHE_URL=redis://localhost:6379/0
# TENANTIQ_THROTTLE_QUERY=30/min
# TENANTIQ_THROTTLE_UPLOAD=20/min
# TENANTIQ_THROTTLE_READ=120/min
# TENANTIQ_QUERY_DAILY_QUOTA=1000
# TENANTIQ_QUERY_MONTHLY_QUOTA=0

# Embeddings (ADR-0004). Local Ollama backend; the model is pulled into the compose `ollama` service.
OLLAMA_BASE_URL=http://localhost:11434
TENANTIQ_EMBEDDING_MODEL=nomic-embed-text

# OIDC: per-tenant issuers are stored in the DB (Tenant.oidc_issuer) and are authoritative.
# This is only a dev bootstrap default pointing at the local Keycloak realm.
OIDC_ISSUER_URL=http://localhost:8080/realms/acme

# Keycloak (docker-compose `dev` profile) — local admin console credentials only
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
